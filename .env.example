# GitHub Personal Access Token (classic or fine-grained)
# REQUIRED to query the GitHub GraphQL API to scout users.
# Create a token with read-only/public profile permissions at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Redis Connection URL (Optional)
# e.g. redis://localhost:6379
# If not set, caching will be disabled and all requests will fetch live from GitHub.
REDIS_URL=
